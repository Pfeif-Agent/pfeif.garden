---
import GrowthBadge from './GrowthBadge.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  slug: string;
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  tags?: string[];
}

const { title, description, publishDate, slug, growthStage, tags = [] } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/writing/${slug}`} class="post-card__link">
    <div class="post-card__meta cluster" style="--cluster-space: var(--spacing-3);">
      <time datetime={publishDate.toISOString()} class="post-card__date">{formattedDate}</time>
      {growthStage && <GrowthBadge stage={growthStage} />}
    </div>
    <h2 class="post-card__title">{title}</h2>
    <p class="post-card__description">{description}</p>
    {tags.length > 0 && (
      <ul class="post-card__tags cluster" style="--cluster-space: var(--spacing-2);">
        {tags.map(tag => <li class="post-card__tag">{tag}</li>)}
      </ul>
    )}
  </a>
</article>

<style>
  .post-card {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: var(--spacing-8);
  }

  .post-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__meta {
    margin-block-end: var(--spacing-3);
  }

  .post-card__date {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .post-card__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-block-end: var(--spacing-2);
    transition: color 150ms ease;
  }

  .post-card__description {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin: 0;
    margin-block-end: var(--spacing-4);
  }

  .post-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-card__tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 2px var(--spacing-2);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
  }
</style>
