---
/**
 * FeaturedCard — dominant highlight card for the homepage.
 *
 * Full diagonal slash treatment at --slash-angle (-14deg).
 * Barlow Condensed at large scale. High contrast warm-on-dark.
 * No growth stage badge (curation implies quality).
 */

interface Props {
  title: string;
  description: string;
  href: string;
  type?: string;
  coverImage?: string;
}

const { title, description, href, type, coverImage } = Astro.props;
---

<article class="featured-card">
  <a href={href} class="featured-card__link">

    {coverImage && (
      <div class="featured-card__image-wrap">
        <img src={coverImage} alt="" class="featured-card__image" loading="lazy" />
      </div>
    )}

    <div class="featured-card__content">
      {/* Full slash treatment — structural diagonal */}
      <div class="featured-card__slash" aria-hidden="true">
        <div class="featured-card__slash-line"></div>
        <div class="featured-card__slash-line"></div>
      </div>

      <div class="featured-card__body">
        {type && <span class="featured-card__type">{type}</span>}
        <h2 class="featured-card__title">{title}</h2>
        <p class="featured-card__description">{description}</p>
        <span class="featured-card__cta">Read →</span>
      </div>
    </div>

  </a>
</article>

<style>
  .featured-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: hidden;
    position: relative;
  }

  .featured-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
    min-height: 320px;
  }

  /* Cover image */
  .featured-card__image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .featured-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
    transition: opacity 300ms ease;
  }

  .featured-card__link:hover .featured-card__image {
    opacity: 0.35;
  }

  /* Content layer */
  .featured-card__content {
    position: relative;
    z-index: 1;
    height: 100%;
    min-height: inherit;
  }

  /* Full slash treatment */
  .featured-card__slash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .featured-card__slash-line {
    position: absolute;
    left: -20%;
    right: -20%;
    height: var(--slash-width);
    background-color: var(--color-warm-400);
    transform: rotate(var(--slash-angle));
    transform-origin: center;
    opacity: 0.6;
  }

  .featured-card__slash-line:first-child {
    top: 35%;
  }

  .featured-card__slash-line:last-child {
    top: calc(35% + var(--slash-width) + var(--slash-gap));
    opacity: 0.25;
  }

  /* Body */
  .featured-card__body {
    padding: var(--spacing-10);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    height: 100%;
    min-height: inherit;
    justify-content: flex-end;
  }

  .featured-card__type {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-warm-400);
    align-self: flex-start;
  }

  .featured-card__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
    font-weight: 800;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
    transition: color 150ms ease;
  }

  .featured-card__link:hover .featured-card__title {
    color: var(--color-warm-400);
  }

  .featured-card__description {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 60ch;
  }

  .featured-card__cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-warm-400);
    transition: letter-spacing 150ms ease;
  }

  .featured-card__link:hover .featured-card__cta {
    letter-spacing: var(--tracking-wider);
  }
</style>
