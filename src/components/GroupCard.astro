---
/**
 * GroupCard — one group's table (A–L) for the WC2026 draft page.
 *
 * Static order is by pre-tournament odds; the live layer reorders rows to the real
 * standing, marks the top two as advancing, and reveals a W-D-L · pts chip.
 *
 * Live layer: live.client.ts (patchGroups) hooks this by bare class / data-attr —
 * .grp[data-group], li[data-team-row], [data-pos-label], [data-group-stat], and the
 * .adv / .adv-pos row classes. Those MUST stay intact, so the styles below use
 * :global() — co-located here for editing, but un-scoped so the cascade and the
 * live script's selectors still reach them. (Same pattern as StandingCard.astro.)
 *
 * Props:
 *   group      — group letter ("A".."L"); also the data-group key
 *   teams      — teams in odds order; each { name, manager }
 *   colorOf    — manager index -> accent color (page helper, passed in) for the owner dot
 *   qualThirds — set of team names currently projected as best-8 thirds (cross-group).
 *                A 3rd-place row in this set gets the green pos-number (currently projected
 *                to advance), same signifier as top-2. Top-2 green is purely positional.
 */
interface GroupTeam {
  name: string;
  manager: number;
}
interface Props {
  group: string;
  teams: GroupTeam[];
  colorOf: (mgr: number) => string;
  qualThirds: Set<string>;
}

const { group, teams, colorOf, qualThirds } = Astro.props;
---

<div class="grp" data-group={group}>
  <h2 class="gh">Group {group}</h2>
  <ul>
    {teams.map((t, idx) => (
      <li data-team-row={t.name} data-pos={idx + 1}
          class:list={[{ "adv-pos": idx < 2 || qualThirds.has(t.name) }]}>
        <span class="pos" data-pos-label>{idx + 1}</span>
        <span class="dot" style={`background:${colorOf(t.manager)}`} aria-hidden="true"></span>
        <span class="tn" data-team={t.name}>{t.name}</span>
        <span class="stat" data-group-stat hidden></span>
      </li>
    ))}
  </ul>
</div>

<style>
  /* ---- GroupCard ----
     All selectors are :global() on purpose — they belong to the page's global
     cascade (the live script reaches in by these names) and are merely co-located
     here for editing. The .dot bit is a shared utility defined on the page; only
     the group-specific rules live here. */
  :global(.grp) {
    /* min-width:0 so the card respects its grid track. Without it the default
       min-width:auto lets the non-shrinkable row content (odds + the margin-auto
       stat chip) push the card wider than its column — it was overflowing the
       right rail by ~37px, reading as "wider than the standings cards". */
    min-width: 0;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 12px;
  }
  /* the name is the most important column — with odds + manager dropped there's room,
     so let it show in full (wrap if a long name needs it) instead of truncating. */
  :global(.grp .tn) {
    min-width: 0;
    flex: 1;
  }
  :global(.grp .gh) {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sage-dim);
    margin-bottom: 8px;
  }
  :global(.grp ul) { list-style: none; margin: 0; padding: 0; }
  :global(.grp li) { display: flex; align-items: center; gap: 8px; padding: 5px 0; }
  :global(.grp .pos) {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--sage-dim);
    width: 12px;
    flex: none;
  }
  :global(.grp .stat) {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--sage-dim);
    flex: none;
    margin-left: auto;
  }
  /* live-driven row states */
  :global(.grp li.adv .tn) { color: var(--chalk); }
  :global(.grp li.adv-pos .pos) { color: var(--grass); }
</style>
