---
interface Props {
  stage: 'draft' | 'active' | 'complete';
}

const { stage } = Astro.props;

const labels: Record<Props['stage'], string> = {
  draft:    '◈ draft',
  active:   '◈ active',
  complete: '◈ complete',
};
---

<span class={`growth-badge growth-badge--${stage}`}>{labels[stage]}</span>

<style>
  .growth-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: 2px var(--spacing-2);
    border-radius: var(--radius-sm);
    border: 1px solid;
  }

  .growth-badge--draft {
    color: var(--color-base-300);
    border-color: var(--color-base-500);
    background-color: color-mix(in srgb, var(--color-base-500) 20%, transparent);
  }

  .growth-badge--active {
    color: var(--color-warm-300);
    border-color: var(--color-warm-500);
    background-color: color-mix(in srgb, var(--color-warm-500) 15%, transparent);
  }

  .growth-badge--complete {
    color: var(--color-warm-400);
    border-color: var(--color-warm-400);
    background-color: color-mix(in srgb, var(--color-warm-400) 12%, transparent);
  }
</style>
