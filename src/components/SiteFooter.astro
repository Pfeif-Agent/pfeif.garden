---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrapper cluster site-footer__inner" style="--cluster-space: var(--spacing-6);">
    <p class="site-footer__copy">
      &copy; {year} Jacob Pfeifer
    </p>
    <nav class="cluster site-footer__links" style="--cluster-space: var(--spacing-6);" aria-label="Footer navigation">
      <a href="/writing">writing</a>
      <a href="/work">work</a>
      <a href="/about">about</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-block-start: auto;
    padding-block: var(--spacing-8);
    border-top: 1px solid var(--color-border-subtle);
  }

  .site-footer__inner {
    justify-content: space-between;
  }

  .site-footer__copy {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .site-footer__links a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: lowercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .site-footer__links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
