---
/**
 * IndexCard — quiet index listing card.
 *
 * Used on /writing and /lab index pages.
 * Slash is a subtle accent only — not the full treatment.
 */
import GrowthBadge from './GrowthBadge.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  href: string;
  type?: string;
  growthStage?: 'draft' | 'active' | 'complete';
  externalUrl?: string;
  coverImage?: string;
}

const {
  title,
  description,
  publishDate,
  href,
  type,
  growthStage,
  externalUrl,
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const target = externalUrl ? externalUrl : href;
const isExternal = !!externalUrl;
---

<article class="index-card">
  <a
    href={target}
    class="index-card__link"
    {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >
    <div class="index-card__slash" aria-hidden="true"></div>

    <div class="index-card__body">
      <div class="index-card__meta">
        <time datetime={publishDate.toISOString()} class="index-card__date">{formattedDate}</time>
        {type && <span class="index-card__type">{type}</span>}
        {isExternal && <span class="index-card__external" aria-label="external link">↗</span>}
      </div>

      <h2 class="index-card__title">{title}</h2>
      <p class="index-card__description">{description}</p>

      {growthStage && <GrowthBadge stage={growthStage} />}
    </div>
  </a>
</article>

<style>
  .index-card {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: var(--spacing-8);
    position: relative;
    overflow: hidden;
  }

  .index-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* Subtle slash accent — appears on hover */
  .index-card__slash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .index-card__slash::before {
    content: '';
    position: absolute;
    left: -10%;
    right: -10%;
    top: 50%;
    height: 1px;
    background-color: var(--color-warm-400);
    transform: rotate(var(--slash-angle));
    transform-origin: center;
    opacity: 0.15;
  }

  .index-card__link:hover .index-card__slash,
  .index-card:hover .index-card__slash {
    opacity: 1;
  }

  .index-card__body {
    position: relative;
    z-index: 1;
  }

  .index-card__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    margin-block-end: var(--spacing-3);
  }

  .index-card__date {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .index-card__type {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .index-card__external {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-inline-start: auto;
  }

  .index-card__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-block-end: var(--spacing-2);
    transition: color 150ms ease;
  }

  .index-card__link:hover .index-card__title {
    color: var(--color-accent);
  }

  .index-card__description {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin: 0;
    margin-block-end: var(--spacing-4);
  }
</style>
