---
/**
 * StandingCard — one manager's standings card for the WC2026 draft page.
 *
 * The whole visible face is the toggle: the card is a native <details>, and the
 * <summary> wraps the entire header (rank · name · points · alive), so a tap
 * anywhere on it opens/closes the roster — no JS needed, full keyboard + a11y for
 * free. The roster <ol> is the disclosed content.
 *
 * IA: rank pip + owner name on top, big points number below, "PTS · X/Y alive"
 * caption under that. Header is grid-driven so it stays put as live data fills in.
 *
 * Live layer: live.client.ts patches this card by data-attribute / bare class
 * (data-mgr-card, data-rank, data-mgr-pts, data-alive, data-team-row, .spts,
 * .sstage, .stand-card.gold|silver|bronze ...). Those hooks MUST stay intact, so
 * the styles below are written with :global() — co-located here for editing, but
 * un-scoped so the cascade and the live script's selectors still reach them.
 *
 * Rank isn't shown — the medal tint (gold/silver/bronze) plus the big points
 * number convey standing, and the live script reorders the cards by rank.
 *
 * Props:
 *   name   — manager/owner name
 *   color  — manager accent color (--rc)
 *   index  — manager index (data-mgr / data-mgr-card key for the live script)
 *   teams  — drafted teams, already sorted by pick
 *   flagUrl — helper mapping a team code to a flag URL (passed in to avoid a
 *             second import path; page already owns it)
 */
interface Team {
  name: string;
  code: string;
}
interface Props {
  name: string;
  color: string;
  index: number;
  teams: Team[];
  flagUrl: (code: string | undefined) => string | null;
}

const { name, color, index, teams, flagUrl } = Astro.props;
---

<details class="stand-card" style={`--rc:${color}`} data-mgr-card={index} data-mgr={index}>
  <summary class="sc-face">
    <span class="sc-name">{name}</span>
    <span class="sc-pts" data-mgr-pts>0</span>
    <span class="sc-cap"><span class="sc-cap-pts">pts</span> · <span class="sc-alive" data-alive>{teams.length}/{teams.length} alive</span></span>
  </summary>
  <ol>
    {teams.map((t) => (
      <li data-team-row={t.name}>
        <img class="flag" src={flagUrl(t.code) ?? ""} alt="" width="22" height="22" loading="lazy" aria-hidden="true" />
        <span class="tn" data-team={t.name}>{t.name}</span>
        <span class="sstage" data-stage-label></span>
        <span class="spts" data-team-pts>0</span>
      </li>
    ))}
  </ol>
</details>

<style>
  /* ---- StandingCard ----
     All selectors are :global() on purpose — see the component doc comment. They
     belong to the page's global cascade (the live script reaches in by these
     names) and are merely co-located here for editing. */

  /* the card is the <details>; the <summary> is its whole tappable face */
  :global(.stand-card) {
    /* fill the grid track exactly; min-width:0 lets it shrink with the column. */
    width: 100%;
    min-width: 0;
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 3px solid var(--rc);
    border-radius: 14px;
    padding: 0;
    overflow: hidden;
    --medal: transparent;
  }
  /* medal tint (live-rank driven): gold/silver/bronze for 1st/2nd/3rd */
  :global(.stand-card.medal) {
    border-top-color: var(--medal);
    background: linear-gradient(180deg, color-mix(in srgb, var(--medal) 12%, transparent), transparent 64px), var(--panel);
  }
  :global(.stand-card.gold)   { --medal: #F2C14E; }
  :global(.stand-card.silver) { --medal: #C9D1D3; }
  :global(.stand-card.bronze) { --medal: #CD8C5C; }

  /* header / tappable face: rank+name on top, big points below, caption under */
  :global(.stand-card .sc-face) {
    cursor: pointer;
    list-style: none;
    user-select: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 13px 15px 14px;
    position: relative;
  }
  :global(.stand-card .sc-face::-webkit-details-marker) { display: none; }

  :global(.stand-card .sc-name) {
    font-weight: 700;
    font-size: 17px;
  }

  /* big points number, under the name. Tinted to match the card's medal rank (the
     top-border tint): gold for 1st, silver for 2nd, bronze for 3rd, so the score reads
     as its own medal. Pre-tournament (no medal class yet) it falls back to gold.
     --medal-text is a brightened variant of each tint, chosen for legibility against
     the dark radial bg (the 12% wash tint is too dim for a text fill). */
  :global(.stand-card .sc-pts) {
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    font-size: 34px;
    line-height: 1;
    color: var(--medal-text, var(--gold));
    margin-top: 6px;
  }
  :global(.stand-card.gold)   { --medal-text: #F2C14E; }
  :global(.stand-card.silver) { --medal-text: #DCE3E5; }
  :global(.stand-card.bronze) { --medal-text: #E0A36B; }

  /* caption: "pts · X/Y alive" under the big number */
  :global(.stand-card .sc-cap) {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--sage-dim);
    margin-top: 4px;
  }
  :global(.stand-card .sc-cap-pts) { text-transform: uppercase; letter-spacing: .1em; }
  :global(.stand-card .sc-alive.out) { color: var(--medal, #CD8C5C); }

  /* disclosure chevron, top-right of the face; rotates when open */
  :global(.stand-card .sc-face::after) {
    content: "▾";
    position: absolute;
    top: 13px;
    right: 15px;
    color: var(--sage-dim);
    transition: transform .15s ease;
  }
  :global(.stand-card[open] .sc-face::after) { transform: rotate(180deg); }

  /* roster list (disclosed content) */
  :global(.stand-card ol) {
    list-style: none;
    margin: 0;
    padding: 0 15px 6px;
    border-top: 1px solid var(--line);
  }
  :global(.stand-card li) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-top: 1px solid rgba(255, 255, 255, .04);
  }
  :global(.stand-card li:first-child) { border-top: 0; }
  :global(.stand-card .flag) {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    flex: none;
    background: var(--panel-2);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .08);
  }
  :global(.stand-card .tn) {
    font-size: 15px;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }
  :global(.stand-card .sstage) {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--sage-dim);
    flex: none;
  }
  :global(.stand-card .spts) {
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
    width: 24px;
    text-align: right;
    flex: none;
  }
  :global(.stand-card li.elim .tn) {
    color: var(--sage-dim);
    text-decoration: line-through;
    text-decoration-color: var(--sage-dim);
  }
  :global(.stand-card li.elim .flag) { filter: grayscale(1) opacity(.5); }
</style>
