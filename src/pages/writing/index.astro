---
import { getCollection } from 'astro:content';
import { getAtprotoPosts } from '../../lib/atproto';
import PageLayout from '../../layouts/PageLayout.astro';
import IndexCard from '../../components/IndexCard.astro';

const [mdPosts, atPosts] = await Promise.all([
  getCollection('writing', ({ data }) => !data.draft),
  getAtprotoPosts(),
]);

// ATProto is canonical — exclude MD posts whose slug is covered by ATProto
const atSlugs = new Set(atPosts.map(p => p.slug));

const mdItems = mdPosts
  .filter(post => !atSlugs.has(post.id))
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    publishDate: post.data.publishDate,
    href: `/writing/${post.id}`,
    type: post.data.type,
    growthStage: post.data.growthStage,
  }));

const atItems = atPosts.map(post => ({
  title: post.title,
  description: post.description,
  publishDate: post.publishDate,
  href: `/writing/${post.slug}`,
  type: 'essay' as const,
  growthStage: undefined,
}));

const posts = [...mdItems, ...atItems]
  .sort((a, b) => b.publishDate.valueOf() - a.publishDate.valueOf());
---

<PageLayout
  title="Writing — pfeif.garden"
  description="Thinking out loud about tools, expression, and the software we live inside."
  currentPage="/writing"
>
  <section class="writing-index wrapper" data-width="narrow">

    <header class="writing-index__header stack" style="--stack-space: var(--spacing-4);">
      <p class="writing-index__label">Writing</p>
      <h1 class="writing-index__title">Thinking out loud.</h1>
      <p class="writing-index__sub">
        Essays, notes, and half-formed thoughts about tools, expression, and the software we live inside.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="writing-index__empty">Nothing here yet. Check back soon.</p>
    ) : (
      <div class="writing-index__posts">
        {posts.map(post => (
          <IndexCard
            title={post.title}
            description={post.description}
            publishDate={post.publishDate}
            href={post.href}
            type={post.type}
            growthStage={post.growthStage}
          />
        ))}
      </div>
    )}

  </section>
</PageLayout>

<style>
  .writing-index {
    padding-block: var(--spacing-16);
  }

  .writing-index__header {
    margin-block-end: var(--spacing-12);
    padding-block-end: var(--spacing-8);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .writing-index__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .writing-index__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    font-weight: 800;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .writing-index__sub {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .writing-index__empty {
    font-family: var(--font-serif);
    color: var(--color-text-muted);
    padding-block: var(--spacing-12);
    text-align: center;
  }
</style>
