---
// World Cup 2026 — The Thread fantasy draft.
// Phase 1 (static) rendered from data + Phase 2 (live ESPN layer, progressive enhancement).
// Static markup is the source of truth; the client script only ADDS live data and degrades
// gracefully if JS is off or ESPN is unreachable. Spec/algorithm: src/lib/wc2026/reference/.

import { MANAGERS, TEAMS, SCORING, TEAM_BY_NAME, flagUrl } from "../../data/draft";
import { FIXTURES, FIXTURE_BY_NUM } from "../../lib/wc2026/fixtures";
import { projectBracket, oddsRanking, GROUPS } from "../../lib/wc2026/bracket";
import StandingCard from "../../components/StandingCard.astro";
import GroupCard from "../../components/GroupCard.astro";

// ---- derived helpers ---------------------------------------------------------

const colorOf = (mgr: number) => MANAGERS[mgr]?.color ?? "#66716B";
const nameOf = (mgr: number) => MANAGERS[mgr]?.name ?? "—";

/** Odds-tier class for favorite highlighting (DESIGN.md). */
function oddsTier(oddsValue: number): "fav" | "mid" | "" {
  if (oddsValue <= 9) return "fav";
  if (oddsValue <= 150) return "mid";
  return "";
}

// US-Eastern (UTC-4, tournament window) localization of kickoffUTC.
// This is a server-side stopgap; the client script re-localizes the visible time to the
// viewer's zone. Day-GROUPING uses US Central — it matches every fixture's venue-local
// date (a 9pm-Pacific kickoff is still "tonight" in CT, but tips past midnight in ET),
// so late West-Coast games land under the correct day. (Confirmed: 0/104 mismatches vs
// the fixtures' own `date` field.)
const ET = "America/New_York";
const CT = "America/Chicago";
const dtf = new Intl.DateTimeFormat("en-US", {
  timeZone: ET, hour: "2-digit", minute: "2-digit", hour12: false,
});
const ddf = new Intl.DateTimeFormat("en-US", {
  timeZone: CT, weekday: "short", month: "short", day: "numeric",
});
// Sortable CT calendar date ("2026-06-11"), used as the day block's data-date so the
// jump-to-today button can string-compare each day against today's CT date.
const isoDateFmt = new Intl.DateTimeFormat("en-CA", {
  timeZone: CT, year: "numeric", month: "2-digit", day: "2-digit",
});
const etTime = (iso: string) => dtf.format(new Date(iso));
const etDateKey = (iso: string) => ddf.format(new Date(iso)); // "Thu, Jun 11" (CT day)
const ctIsoDate = (iso: string) => isoDateFmt.format(new Date(iso)); // "2026-06-11" (CT day)

// ---- bracket projection ------------------------------------------------------

const projection = projectBracket(); // pre-tournament odds projection (used for the R32
                                     // pairing structure + the best-thirds set, not winners)
const resolveSlot = projection.resolveSlot;
// The 8 best third-placed teams (cross-group) under the odds projection. The group
// cards green the pos-number of every team currently projected to advance: top-2 of
// each group (positional) PLUS any 3rd-placed team in this set. The live layer later
// recomputes this from real standings (state.bracket.qualifyingThirds).
const qualThirds = new Set(projection.qualifyingThirds);

// We project the bracket STRUCTURE but not its RESULTS: a knockout slot shows a real team
// only when the team is determined by group seeding or the best-thirds projection — i.e. the
// R32 (slot codes 1A/2B/3A/B/C…). Anything fed by a match WINNER/LOSER (W74, L101 → R16 and
// beyond) is a predicted result, so it renders "TBD" until the live layer fills it from real
// games. (The live layer keys off the same data-slot attrs, so it still resolves teams in.)
const isResultDependentSlot = (code: string): boolean => /^[WL]\d+$/.test(String(code));
/** A placeholder "team view" for an unresolved (result-dependent) knockout slot. */
const TBD_VIEW = { name: "TBD", mgr: null, color: "#66716B", mgrName: null } as const;
/** teamView for a knockout slot, but TBD if the slot depends on a not-yet-played result. */
function koSlotView(code: string) {
  return isResultDependentSlot(code) ? TBD_VIEW : teamView(resolveSlot(code));
}

/** Round-tag abbreviations for the schedule/bracket. */
const ROUND_TAG: Record<string, string> = {
  "Round of 32": "R32", "Round of 16": "R16", "Quarter-final": "QF",
  "Semi-final": "SF", "Match for third place": "3rd", Final: "Final",
};

/** A team name resolved for display, with its owner color (or neutral if unowned). */
function teamView(name: string) {
  const t = TEAM_BY_NAME[name];
  return {
    name,
    mgr: t ? t.manager : null,
    color: t ? colorOf(t.manager) : "#66716B",
    mgrName: t ? nameOf(t.manager) : null,
  };
}

// ---- Upcoming: all 104 fixtures grouped by ET calendar day -------------------

interface SchedRow {
  num: number; time: string; t1: ReturnType<typeof teamView>;
  t2: ReturnType<typeof teamView>; tag: string; predicted: boolean;
  group: string | null;
}
const schedByDay = new Map<string, SchedRow[]>();
const dayIso = new Map<string, string>(); // day label -> sortable CT ISO date
const dayOrder: string[] = [];
for (const m of [...FIXTURES].sort((a, b) => a.kickoffUTC.localeCompare(b.kickoffUTC))) {
  const day = etDateKey(m.kickoffUTC);
  if (!schedByDay.has(day)) {
    schedByDay.set(day, []); dayOrder.push(day);
    dayIso.set(day, ctIsoDate(m.kickoffUTC));
  }
  const predicted = m.stage === "knockout";
  schedByDay.get(day)!.push({
    num: m.num,
    time: etTime(m.kickoffUTC),
    // group fixtures have literal team names; knockout fixtures whose teams depend on a
    // result render TBD (koSlotView handles both — real R32 pairings, TBD beyond).
    t1: koSlotView(m.team1),
    t2: koSlotView(m.team2),
    tag: m.group ? m.group : (ROUND_TAG[m.round] ?? m.round),
    predicted,
    group: m.group,
  });
}

// ---- Bracket: knockout matches grouped by round ------------------------------

// Order is also the left→right column order in the bracket. The Final is the climax and
// sits as the rightmost column. The 3rd-place match (fed by the SF losers, off the
// championship path) is NOT a column — it's stacked under the Final inside that column.
const KO_ROUNDS = [
  { round: "Round of 32", dt: "Jun 28 – Jul 3" },
  { round: "Round of 16", dt: "Jul 4–7" },
  { round: "Quarter-final", dt: "Jul 9–11" },
  { round: "Semi-final", dt: "Jul 14–15" },
  { round: "Final", dt: "Jul 19" },
];
interface BrkMatch {
  num: number; t1: ReturnType<typeof teamView>; t2: ReturnType<typeof teamView>;
  // no projected winner — we don't predict knockout RESULTS, only the R32 pairing structure.
}
// The knockout draw is a binary tree rooted at the Final (#104); its feeder edges
// (W74/W77 → #89, etc.) are NOT sequential, so a plain num-sort scrambles which
// matches share a next-round slot. A DFS in-order traversal of that tree yields, per
// round, the vertical sequence in which adjacent matches feed the same parent — the
// ordering every real bracket layout needs so a winner lines up with the slot it fills.
const feedersOf = (num: number): (number | null)[] => {
  const m = FIXTURE_BY_NUM[num];
  return [m.team1, m.team2].map((c) => {
    const mm = /^[WL](\d+)$/.exec(String(c));
    return mm ? Number(mm[1]) : null;
  });
};
const ROUND_TREE_ORDER: Record<string, number[]> = (() => {
  const order: Record<string, number[]> = {};
  const visit = (num: number) => {
    const m = FIXTURE_BY_NUM[num];
    (order[m.round] ??= []);
    const [f1, f2] = feedersOf(num);
    if (f1) visit(f1);
    order[m.round].push(num);
    if (f2) visit(f2);
  };
  visit(104); // root = Final; the 3rd-place match (103) hangs off the SF losers, add it apart
  order["Match for third place"] = [103];
  return order;
})();

function bracketRound(round: string): BrkMatch[] {
  const order = ROUND_TREE_ORDER[round] ?? [];
  return FIXTURES.filter((m) => m.stage === "knockout" && m.round === round)
    .sort((a, b) => order.indexOf(a.num) - order.indexOf(b.num))
    // R32 shows real teams (group seeds + projected best-thirds); every later round depends on
    // results we don't predict, so its slots render TBD. No winner is projected anywhere.
    .map((m) => ({ num: m.num, t1: koSlotView(m.team1), t2: koSlotView(m.team2) }));
}

// ---- Rosters (per manager, draft order) --------------------------------------

const rosters = MANAGERS.map((mgr, i) => ({
  ...mgr, index: i,
  teams: TEAMS.filter((t) => t.manager === i).sort((a, b) => a.pick - b.pick),
}));

// ---- By group (teams ordered by odds within group) ---------------------------

const groupCards = GROUPS.map((g) => ({
  group: g,
  teams: oddsRanking(g).map((name) => TEAM_BY_NAME[name]).filter(Boolean),
}));

// ---- Draft board (overall snake order) ---------------------------------------

const board = [...TEAMS].sort((a, b) => a.pick - b.pick);

// ---- Scoring ladder (from SCORING — the locked B+2 values) -------------------

const championMax = 9 + SCORING.advanceToR32 + SCORING.winR32 + SCORING.winR16 +
  SCORING.winQF + SCORING.winSF + SCORING.winFinal;
const scoringRows: [string, number][] = [
  ["Group stage — win", SCORING.groupWin],
  ["Group stage — draw", SCORING.groupDraw],
  ["Advance out of the group (reach R32)", SCORING.advanceToR32],
  ["Win in Round of 32", SCORING.winR32],
  ["Win in Round of 16", SCORING.winR16],
  ["Win in Quarter-final", SCORING.winQF],
  ["Win in Semi-final", SCORING.winSF],
  ["Win the Final", SCORING.winFinal],
];
