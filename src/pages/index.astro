---
import PageLayout from '../layouts/PageLayout.astro';
import Slash from '../components/Slash.astro';
---

<PageLayout title="pfeif.garden" description="Jacob Pfeifer — software for human expression.">

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="wrapper stack" style="--stack-space: var(--spacing-8);">
      <p class="hero__label">Jacob Pfeifer</p>
      <h1 class="hero__title">
        Software for<br />
        <em>human expression.</em>
      </h1>
      <p class="hero__sub">
        Building tools that help people say what they actually mean.
      </p>
    </div>
  </section>

  <Slash />

  <!-- ── INTRO ─────────────────────────────────────────────────────────────── -->
  <section class="intro">
    <div class="wrapper stack" data-width="narrow" style="--stack-space: var(--spacing-6);">
      <p class="intro__text">
        <!-- TODO: real bio copy -->
        I make software that bends toward self-expression and away from extraction.
        This is where I write about it, share work, and think out loud.
      </p>
      <a href="/about" class="intro__cta">More about me →</a>
    </div>
  </section>

</PageLayout>

<style>
  /* ── HERO ───────────────────────────────────────────────────────────────── */

  .hero {
    padding-block: var(--spacing-24) var(--spacing-16);
  }

  .hero__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .hero__title {
    font-size: clamp(var(--text-5xl), 8vw, var(--text-7xl));
    font-weight: 800;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
    text-transform: uppercase;
  }

  .hero__title em {
    font-style: normal;
    color: var(--color-accent);
  }

  .hero__sub {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 40ch;
  }

  /* ── INTRO ──────────────────────────────────────────────────────────────── */

  .intro {
    padding-block: var(--spacing-16);
  }

  .intro__text {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .intro__cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-accent);
  }

  .intro__cta:hover {
    color: var(--color-warm-300);
    text-decoration: none;
  }
</style>
